# Copy this file to .env and fill in your values.
# MOCK_MODE=true lets you run everything locally without any paid API keys.

# --- App ---
DEBUG=true
HOST=0.0.0.0
PORT=8000
MOCK_MODE=true

# --- Agent ---
AGENT_NAME=Aria
CONFIDENCE_THRESHOLD=0.6

# --- OpenAI (GPT-4o for LLM, Whisper for STT) ---
# Required when MOCK_MODE=false
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- ElevenLabs (Text-to-Speech) ---
# Required when MOCK_MODE=false
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Twilio (for real phone calls) ---
# Required only for live call testing
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# --- Redis ---
REDIS_URL=redis://localhost:6379
SESSION_TTL_SECONDS=3600
